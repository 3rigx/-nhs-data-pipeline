# ============================================
# NHS Data Pipeline - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Snowflake (Production) ---
SNOWFLAKE_ACCOUNT=xxxxxxx-xxxxxxx
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=NHS_PIPELINE_WH
SNOWFLAKE_DATABASE=NHS_DATA_PLATFORM
SNOWFLAKE_ROLE=DBT_ROLE

# --- DuckDB (Local Development) ---
DUCKDB_PATH=data/duckdb/nhs_pipeline.duckdb

# --- dbt ---
DBT_PROFILES_DIR=./nhs_dbt
DBT_TARGET=dev

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000